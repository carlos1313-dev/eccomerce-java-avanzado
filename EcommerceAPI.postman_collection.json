{
  "info": {
    "name": "E-Commerce API",
    "description": "Colección completa para la API de e-commerce. Ejecutar en orden: 1) Register, 2) Login (guarda el token), 3) resto de endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "clienteToken", "value": "", "type": "string" },
    { "key": "productId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Autenticación",
      "item": [
        {
          "name": "Registrar Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Administrador\",\n  \"email\": \"admin@ecommerce.com\",\n  \"password\": \"Admin1234\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Registrar Cliente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cliente Ejemplo\",\n  \"email\": \"cliente@ecommerce.com\",\n  \"password\": \"Cliente1234\",\n  \"role\": \"CLIENTE\"\n}"
            }
          }
        },
        {
          "name": "Login Admin → guarda token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('adminToken', json.token);",
                  "  console.log('Token admin guardado');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ecommerce.com\",\n  \"password\": \"Admin1234\"\n}"
            }
          }
        },
        {
          "name": "Login Cliente → guarda token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('clienteToken', json.token);",
                  "  console.log('Token cliente guardado');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@ecommerce.com\",\n  \"password\": \"Cliente1234\"\n}"
            }
          }
        },
        {
          "name": "Login con credenciales inválidas (debe dar 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ecommerce.com\",\n  \"password\": \"WrongPassword\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Productos",
      "item": [
        {
          "name": "Listar productos (público)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "Crear producto (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('productId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Gaming X1\",\n  \"description\": \"Laptop de alto rendimiento con RTX 4070\",\n  \"price\": 2499.99,\n  \"stock\": 10\n}"
            }
          }
        },
        {
          "name": "Crear producto sin auth (debe dar 403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Producto Pirata\",\n  \"price\": 1.00,\n  \"stock\": 100\n}"
            }
          }
        },
        {
          "name": "Obtener producto por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Actualizar producto (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Gaming X1 Pro\",\n  \"description\": \"Versión actualizada con más RAM\",\n  \"price\": 2699.99,\n  \"stock\": 8\n}"
            }
          }
        },
        {
          "name": "Eliminar producto - soft delete (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "3. Órdenes",
      "item": [
        {
          "name": "Crear orden (CLIENTE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
            ],
            "url": "{{baseUrl}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": {{productId}},\n      \"quantity\": 2\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Crear orden con stock insuficiente (debe dar 409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
            ],
            "url": "{{baseUrl}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": {{productId}},\n      \"quantity\": 9999\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Mis órdenes (CLIENTE)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
            "url": "{{baseUrl}}/api/orders/my"
          }
        },
        {
          "name": "Todas las órdenes (ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "Todas las órdenes con token CLIENTE (debe dar 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
            "url": "{{baseUrl}}/api/orders"
          }
        }
      ]
    },
    {
      "name": "4. Auditoría (solo ADMIN)",
      "item": [
        {
          "name": "Todos los logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/audit"
          }
        },
        {
          "name": "Logs por usuario",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/audit/user/cliente@ecommerce.com"
          }
        },
        {
          "name": "Logs de órdenes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/audit/entity/ORDER"
          }
        },
        {
          "name": "Auditoría con token CLIENTE (debe dar 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
            "url": "{{baseUrl}}/api/audit"
          }
        }
      ]
    }
  ]
}
